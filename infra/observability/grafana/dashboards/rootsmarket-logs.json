  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "rootsmarket-loki"
        },
        "definition": "label_values({application=\"rootsmarket\"}, service)",
        "query": "label_values({application=\"rootsmarket\"}, service)",
        "refresh": 1,
        "sort": 1,
        "regex": "",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": []
      },
      {
        "name": "severity",
        "label": "Severity",
        "type": "custom",
        "query": "All : .*,Info : info,Warning : warn|warning,Error : error,Debug : debug",
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "Info",
            "value": "info"
          },
          {
            "selected": false,
            "text": "Warning",
            "value": "warn|warning"
          },
          {
            "selected": false,
            "text": "Error",
            "value": "error"
          },
          {
            "selected": false,
            "text": "Debug",
            "value": "debug"
          }
        ]
      }
    ]
  },
