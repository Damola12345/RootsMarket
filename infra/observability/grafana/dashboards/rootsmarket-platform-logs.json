          "editorMode": "code",
          "expr": "sum(count_over_time({application=\"rootsmarket\", log_type=\"platform\", service=\"postgres\"} |~ \"(^|[[:space:]])(WARNING|ERROR|FATAL|PANIC):\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 5,
      "title": "Messaging Error Signals",
      "description": "RabbitMQ error, critical and failed-operation messages.",
