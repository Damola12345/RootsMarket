{
  "id": null,
  "uid": "rootsmarket-platform-logs",
  "title": "RootsMarket Platform Logs",
  "description": "Mixed-format infrastructure and observability logs collected by Grafana Alloy and stored in Loki.",
  "tags": [
    "rootsmarket",
    "platform",
    "infrastructure",
    "logs",
    "loki",
    "alloy"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "schemaVersion": 41,
  "version": 2,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m"
    ],
    "time_options": [
      "5m",
      "15m",
      "30m",
      "1h",
      "3h",
      "6h",
      "12h",
      "24h",
      "2d",
      "7d"
    ]
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "loki",
        "label": "Loki datasource",
        "type": "datasource",
        "query": "loki",
        "refresh": 1,
        "options": [],
        "current": {}
      },
      {
        "name": "service",
        "label": "Platform Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "$loki"
        },
        "definition": "label_values({application=\"rootsmarket\", log_type=\"platform\"}, service)",
        "query": "label_values({application=\"rootsmarket\", log_type=\"platform\"}, service)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": []
      },
      {
        "name": "text_filter",
        "label": "Text Filter",
        "type": "textbox",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Platform Logs",
      "description": "Total platform and infrastructure log entries in the selected time range.",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "$loki"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "instant",
          "editorMode": "code",
          "expr": "sum(count_over_time({application=\"rootsmarket\", log_type=\"platform\", service=~\"$service\"}[$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 2,
      "title": "Platform Error Signals",
      "description": "Error and fatal severity markers. Uses anchored severity patterns instead of matching every occurrence of the word error.",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "$loki"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "instant",
          "editorMode": "code",
          "expr": "sum(count_over_time({application=\"rootsmarket\", log_type=\"platform\", service=~\"$service\"} |~ \"(?i)(^|[[:space:]])(level|lvl|severity)=(error|err|fatal)([[:space:]]|$)|(^|[[:space:]])(ERROR|FATAL|PANIC)(:|[[:space:]])|\\\\[(error|fatal)\\\\]\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Lifecycle Signals",
      "description": "Approximate container lifecycle messages. Actual restart counters should continue to come from cAdvisor metrics.",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "$loki"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "instant",
          "editorMode": "code",
          "expr": "sum(count_over_time({application=\"rootsmarket\", log_type=\"platform\", service=~\"$service\"} |~ \"(?i)(restarting|restart detected|shutting down|shutdown complete|terminated unexpectedly|starting server|ready to accept connections)\" [$__range])) or vector(0)"
        }
      ]
    },
    {
      "id": 4,
