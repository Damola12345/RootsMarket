          "editorMode": "code",
          "expr": "sum(count_over_time({application=\"rootsmarket\", log_type=\"platform\", service=\"rabbitmq\"} |~ \"(?i)(\\\\[error\\\\]|\\\\[critical\\\\]|(^|[[:space:]])error:|failed to|connection.*closed unexpectedly)\" [$__range])) or vector(0)"
        }
